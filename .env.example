# === cPanel / production ===
NODE_ENV=production
# cPanel Node.js sets PORT automatically — do not hardcode in production
# PORT=3000

NEXT_PUBLIC_SITE_URL=https://yourdomain.com
NEXTAUTH_URL=https://yourdomain.com
NEXTAUTH_SECRET=generate-a-long-random-string-here

# MySQL from cPanel → MySQL Databases
DATABASE_URL="mysql://cpanel_user:password@localhost:3306/cpanel_dbname"

# Admin login (Credentials provider — works without Google)
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=change-this-password

# Optional: Google OAuth for /signin
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Set true if image optimization fails on shared hosting
# CPANEL_IMAGE_UNOPTIMIZED=true
